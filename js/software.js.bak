/**
 * 软件著作权表单组件 - render function 版本
 */
const SoftwareForm = {
  props: {
    form: { type: Object, required: true },
    applicants: { type: Array, required: true }
  },
  emits: ['save'],
  data() {
    return {
      sourceFiles: [],
      dragOver: false,
      sourceCodeSettings: { linesPerPage: 50, frontPages: 30, backPages: 30 }
    };
  },
  computed: {
    mergedText() { return SourceCodeSplitter.merge(this.sourceFiles); },
    sourceCodeText() { return this.form.data.sourceCodeText || ''; },
    totalLines() {
      if (!this.sourceCodeText) return 0;
      return this.sourceCodeText.split(/\r?\n/).length;
    },
    totalPages() {
      return SourceCodeSplitter.calcPages(this.totalLines, this.sourceCodeSettings.linesPerPage);
    }
  },
  watch: {
    mergedText(val) {
      this.form.data.sourceCodeText = val;
      this.form.data.lines = val ? val.split(/\r?\n/).length : 0;
    },
    sourceCodeText(val) {
      this.form.data.sourceCodeText = val;
      this.form.data.lines = val ? val.split(/\r?\n/).length : 0;
    }
  },
  mounted() {
    this.form.data.sourceCodeSettings = this.sourceCodeSettings;
  },
  methods: {
    handleSourceFiles(e) {
      const files = Array.from(e.target.files);
      this.loadFiles(files);
      e.target.value = '';
    },
    handleSourceFilesDrop(e) {
      e.preventDefault();
      this.dragOver = false;
      const files = Array.from(e.dataTransfer.files);
      this.loadFiles(files);
    },
    async loadFiles(files) {
      const loaded = await SourceCodeSplitter.loadFiles(files);
      this.sourceFiles = this.sourceFiles.concat(loaded);
    },
    removeSourceFile(idx) { this.sourceFiles.splice(idx, 1); },
    clearSourceFiles() { this.sourceFiles = []; },
    async pasteSourceCode() {
      const text = prompt('直接粘贴源程序文本（Ctrl+V 后按确定）：');
      if (text) {
        this.sourceFiles = [{
          name: `粘贴内容-${Date.now()}.txt`,
          size: text.length,
          text: text,
          lines: text.split(/\r?\n/).length
        }];
      }
    },
    async exportApplication() {
      if (!this.form.applicantId) { alert('请先选择申请人'); return; }
      const applicant = await Storage.getApplicant(this.form.applicantId);
      if (!this.form.name) { alert('请填写软件全称'); return; }
      try {
        const doc = PdfGenerator.generateSoftwareApplication(this.form, applicant);
        const filename = `软著申请表-${this.form.name}-${Date.now()}.pdf`;
        PdfGenerator.savePdf(doc, filename);
      } catch (e) {
        alert('生成失败：' + e.message);
        console.error(e);
      }
    },
    async exportSourceCode() {
      if (!this.form.applicantId) { alert('请先选择申请人'); return; }
      if (!this.sourceCodeText) { alert('请先上传源程序'); return; }
      const applicant = await Storage.getApplicant(this.form.applicantId);
      try {
        const doc = PdfGenerator.generateSourceCodeDocument(this.form, applicant);
        const filename = `源程序-${this.form.name}-${Date.now()}.pdf`;
        PdfGenerator.savePdf(doc, filename);
      } catch (e) {
        alert('生成失败：' + e.message);
        console.error(e);
      }
    }
  },
  render() {
    const h = Vue.h;
    const f = this.form;
    const d = f.data || {};
    const self = this;

    function field(label, input, span) {
      return h('label', { class: 'field' + (span === 'full' ? ' full' : '') }, [
        h('span', { class: 'label' }, label),
        input
      ]);
    }

    function txt(label, prop, placeholder, type) {
      return field(label, h('input', {
        type: type || 'text',
        value: d[prop] || '',
        onInput: (e) => { d[prop] = e.target.value; },
        placeholder: placeholder || ''
      }));
    }

    function sel(label, prop, options) {
      return field(label, h('select', {
        value: d[prop] || options[0].value,
        onChange: (e) => { d[prop] = e.target.value; }
      }, options.map(o => h('option', { value: o.value }, o.label))));
    }

    function date(label, prop) {
      return field(label, h('input', {
        type: 'date', value: d[prop] || '',
        onInput: (e) => { d[prop] = e.target.value; }
      }));
    }

    function area(label, prop, placeholder, rows) {
      return field(label, h('textarea', {
        value: d[prop] || '',
        onInput: (e) => { d[prop] = e.target.value; },
        placeholder: placeholder || '',
        rows: rows || 3
      }), 'full');
    }

    // 申请人
    const applicantSection = h('div', { class: 'section' }, [
      h('h3', null, '著作权人'),
      h('p', { class: 'sub' }, '本软著的著作权登记人。如未设置，请先到「申请人」页面添加。'),
      h('div', { class: 'form-grid' }, [
        field('选择著作权人 *', h('select', {
          value: f.applicantId,
          onChange: (e) => { f.applicantId = e.target.value; }
        }, [
          h('option', { value: '' }, '— 请选择 —'),
          ...this.applicants.map(a => h('option', { value: a.id }, `${a.name}（${a.type==='individual'?'个人':'企业'}）`))
        ]), 'full')
      ])
    ]);

    // 基本信息
    const basicSection = h('div', { class: 'section' }, [
      h('h3', null, '软件基本信息'),
      h('div', { class: 'form-grid' }, [
        field('软件全称 *', h('input', {
          type: 'text', value: f.name || '',
          onInput: (e) => { f.name = e.target.value; },
          placeholder: '必须与源程序头部声明一致'
        })),
        txt('软件简称', 'abbr', '选填'),
        txt('版本号 *', 'version', '如：1.0.0'),
        date('开发完成日期 *', 'completionDate'),
        date('首次发表日期', 'publishDate'),
        sel('发表状态', 'publishStatus', [
          { value: '已发表', label: '已发表' },
          { value: '未发表', label: '未发表' }
        ]),
        txt('开发语言 *', 'lang', '如：Python / Java / C++'),
        field('代码行数', h('input', {
          type: 'text',
          value: this.sourceCodeText ? (this.sourceCodeText.split(/\r?\n/).length + ' 行') : '上传源程序后自动计算',
          readonly: true
        })),
        area('技术特点 / 主要功能 *', 'features', '概括软件用途、采用的技术、解决什么问题。详细功能说明放在「软件说明书」。', 4)
      ])
    ]);

    // 源程序
    const sourceSection = h('div', { class: 'section' }, [
      h('h3', null, '源程序鉴别材料'),
      h('p', { class: 'sub' }, '要求：取源代码前 30 页 + 后 30 页，每页 50 行（共 60 页）。支持：.py / .js / .java / .cpp / .c / .go / .rs / .txt 等文本格式。'),
      h('div', {
        class: 'file-drop',
        onClick: () => { if (self.$refs.sourceFileInput) self.$refs.sourceFileInput.click(); },
        onDragover: (e) => { e.preventDefault(); self.dragOver = true; },
        onDragleave: () => { self.dragOver = false; },
        onDrop: (e) => self.handleSourceFilesDrop(e)
      }, [
        h('p', null, '📂 点击选择或拖拽源程序文件到这里'),
        h('p', { class: 'hint' }, '可一次选多个；Python 建议合并成一个；Java 建议按模块拆开'),
        h('p', { class: 'hint' }, [
          '没有源码文件？',
          h('a', {
            href: '#',
            onClick: (e) => { e.preventDefault(); e.stopPropagation(); self.pasteSourceCode(); }
          }, '直接粘贴文本')
        ])
      ]),
      h('input', {
        ref: 'sourceFileInput', type: 'file', multiple: true,
        accept: '.py,.js,.ts,.jsx,.tsx,.java,.cpp,.c,.h,.hpp,.cs,.go,.rs,.php,.rb,.swift,.kt,.txt,.html,.css,.json,.xml,.yaml,.yml,.md,.sh,.sql',
        style: 'display:none',
        onChange: (e) => self.handleSourceFiles(e)
      }),
      this.sourceFiles.length > 0 ? h('div', { class: 'file-list' }, [
        ...this.sourceFiles.map((f, idx) => h('div', { class: 'file-item', key: idx }, [
          h('span', null, [
            '📄 ' + f.name + ' ',
            h('span', { class: 'muted' }, `(${f.lines} 行 · ${(f.size/1024).toFixed(1)} KB)`)
          ]),
          h('button', { onClick: () => self.removeSourceFile(idx) }, '移除')
        ])),
        h('div', { style: 'margin-top:8px', class: 'row between' }, [
          h('span', { class: 'muted' }, `合计：${this.sourceFiles.length} 个文件 / ${this.totalLines} 行 / 约 ${this.totalPages} 页`),
          h('button', { class: 'btn-link', style: 'color:#dc2626', onClick: () => self.clearSourceFiles() }, '清空全部')
        ])
      ]) : null
    ]);

    // 切分规则
    const settingsSection = this.totalPages > 0 ? h('div', { class: 'section' }, [
      h('h3', null, '源程序切分规则'),
      h('p', { class: 'sub' }, '确保按规则取前 N 页 + 后 N 页，合并成一个 PDF。'),
      h('div', { class: 'form-grid' }, [
        field('每页行数 *', h('input', {
          type: 'number', value: this.sourceCodeSettings.linesPerPage,
          min: 1,
          onInput: (e) => { self.sourceCodeSettings.linesPerPage = parseInt(e.target.value, 10) || 50; }
        })),
        field('前 N 页 *', h('input', {
          type: 'number', value: this.sourceCodeSettings.frontPages,
          min: 0,
          onInput: (e) => { self.sourceCodeSettings.frontPages = parseInt(e.target.value, 10) || 0; }
        })),
        field('后 N 页 *', h('input', {
          type: 'number', value: this.sourceCodeSettings.backPages,
          min: 0,
          onInput: (e) => { self.sourceCodeSettings.backPages = parseInt(e.target.value, 10) || 0; }
        })),
        field('实际输出', h('div', { style: 'padding:8px 0;color:var(--text-muted);font-size:13px' },
          `前 ${Math.min(this.sourceCodeSettings.frontPages, this.totalPages)} 页 + 跳中间 ${Math.max(0, this.totalPages - this.sourceCodeSettings.frontPages - this.sourceCodeSettings.backPages)} 页 + 后 ${Math.min(this.sourceCodeSettings.backPages, this.totalPages)} 页`
        ))
      ])
    ]) : null;

    // 权利
    const rightSection = h('div', { class: 'section' }, [
      h('h3', null, '权利与申请方式'),
      h('div', { class: 'form-grid' }, [
        sel('权利取得方式', 'rightWay', [
          { value: '原始', label: '原始（独立开发）' },
          { value: '继承', label: '继承' },
          { value: '受让', label: '受让' }
        ]),
        sel('申请办理方式', 'handleWay', [
          { value: '自办', label: '自办' },
          { value: '代理', label: '委托代理' }
        ]),
        d.handleWay === '代理' ? txt('代理人姓名', 'agentName', '') : null,
        d.handleWay === '代理' ? txt('代理机构', 'agentOrg', '') : null
      ].filter(Boolean))
    ]);

    // 状态
    const statusSection = h('div', { class: 'section' }, [
      h('h3', null, '申请状态 / 备注'),
      h('div', { class: 'form-grid' }, [
        field('当前状态', h('select', {
          value: f.status || 'draft',
          onChange: (e) => { f.status = e.target.value; }
        }, [
          h('option', { value: 'draft' }, '草稿'),
          h('option', { value: 'applied' }, '已申请'),
          h('option', { value: 'reviewing' }, '审查中'),
          h('option', { value: 'approved' }, '已登记'),
          h('option', { value: 'rejected' }, '驳回')
        ])),
        txt('登记号', 'registrationNo', '登记成功后分配'),
        area('备注', 'notes', '其他需要记录的', 3)
      ])
    ]);

    const actionRow = h('div', { class: 'row gap-12', style: 'margin-top:24px;flex-wrap:wrap' }, [
      h('button', { class: 'btn-primary', onClick: () => self.$emit('save') }, '保存'),
      h('button', { class: 'btn', onClick: () => self.exportApplication() }, '导出申请表 PDF'),
      h('button', { class: 'btn', onClick: () => self.exportSourceCode() }, '导出源程序 60 页 PDF')
    ]);

    return h('div', null, [
      applicantSection,
      basicSection,
      sourceSection,
      settingsSection,
      rightSection,
      statusSection,
      actionRow
    ]);
  }
};
